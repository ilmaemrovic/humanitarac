{
  "ConnectionStrings": {
    "DefaultConnection": "Server=${DB_HOST:localhost};Port=${DB_PORT:3306};Database=${DB_NAME:humanitarac_db};User=${DB_USER:humanitarac};Password=${DB_PASSWORD:humanitarac_pass}"
  },
  "Jwt": {
    "Key": "${JWT_KEY:very_secret_development_key_please_change_in_production}",
    "Issuer": "${JWT_ISSUER:humanitarac.local}",
    "Audience": "${JWT_AUDIENCE:humanitarac.local}",
    "ExpireMinutes": 60
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "System": "Warning"
    }
  },
  "AllowedHosts": "*"
}
